{
  "competition": "CCO",
  "repo": "zeokin/Cuda-Compute-OSS",
  "version": 1,
  "artifact": "kernel.py",
  "harness": "benchmark.py",
  "kernel_language": "triton",
  "tracks": ["rms_norm", "matmul", "qkv_part_rope", "swiglu_input_quant", "dsa_forward"],
  "kernel_py_size_cap_bytes": 65536,

  "locked_paths": [
    "benchmark.py",
    "references",
    "kernel_configs",
    "cco",
    "champions",
    "runtime",
    "cco.config.json",
    "payload-schema.json",
    "pyproject.toml",
    "uv.lock"
  ],

  "no_delegation": {
    "_comment": "Canonical denylists. cco/guard_kernel.py (static) and cco/dispatch_trap.py (runtime) load these; the modules' hardcoded defaults must stay equal to these lists.",
    "static": {
      "deny_qualified_names": [
        "torch.matmul", "torch.mm", "torch.bmm", "torch.addmm", "torch.baddbmm",
        "torch.addbmm", "torch.einsum", "torch.tensordot", "torch.inner", "torch.outer",
        "torch.mv", "torch.dot", "torch.vdot", "torch.chain_matmul", "torch.kron",
        "torch.conv1d", "torch.conv2d", "torch.conv3d", "torch.conv_transpose2d",
        "torch.softmax", "torch.log_softmax",
        "torch.rms_norm", "torch.layer_norm", "torch.group_norm", "torch.silu", "torch.glu",
        "torch._scaled_mm", "torch._int_mm", "torch._weight_int4pack_mm", "torch._weight_int8pack_mm",
        "torch.compile",
        "torch.load", "torch.save",
        "torch.cuda.Stream", "torch.cuda.ExternalStream", "torch.cuda.stream", "torch.cuda.StreamContext",
        "torch.cuda.set_stream", "torch.cuda.current_stream", "torch.cuda.default_stream",
        "torch.cuda.Event", "torch.cuda.graph", "torch.cuda.CUDAGraph",
        "torch.cuda.make_graphed_callables", "torch.cuda.graph_pool_handle",
        "torch.Stream", "torch.Event",
        "torch.cuda.memory_allocated", "torch.cuda.max_memory_allocated",
        "torch.cuda.memory_reserved", "torch.cuda.max_memory_reserved",
        "torch.cuda.memory_cached", "torch.cuda.max_memory_cached",
        "torch.cuda.memory_stats", "torch.cuda.memory_stats_as_nested_dict",
        "torch.cuda.memory_snapshot", "torch.cuda.memory_summary", "torch.cuda.mem_get_info",
        "torch.cuda.reset_peak_memory_stats", "torch.cuda.reset_accumulated_memory_stats",
        "torch.cuda.reset_max_memory_allocated", "torch.cuda.reset_max_memory_cached"
      ],
      "deny_qualified_prefixes": [
        "torch.nn.functional", "torch.ops", "torch._C", "torch.linalg", "torch.utils.cpp_extension",
        "torch.overrides", "torch.utils._python_dispatch",
        "torch._dynamo", "torch._inductor", "torch.fx", "torch.jit", "torch.classes",
        "torch.cuda.graphs", "torch.cuda.memory", "torch.cuda.streams"
      ],
      "deny_methods": [
        "matmul", "mm", "bmm", "addmm", "baddbmm", "addbmm", "einsum", "tensordot",
        "softmax", "log_softmax", "scaled_dot_product_attention",
        "attrgetter", "methodcaller", "itemgetter", "format", "format_map",
        "load_module", "exec_module", "get_data", "set_data", "source_to_code", "get_code",
        "get_source", "create_module", "get_filename", "get_resource_reader", "_cache_bytecode"
      ],
      "deny_builtins": [
        "eval", "exec", "compile", "__import__", "getattr", "setattr", "globals", "vars", "open",
        "attrgetter", "methodcaller", "itemgetter", "__builtins__"
      ],
      "deny_dunder_attrs": [
        "__dict__", "__getattribute__", "__getattr__", "__globals__", "__builtins__",
        "__subclasses__", "__bases__", "__mro__", "__base__", "__class__",
        "__traceback__", "with_traceback", "tb_frame", "tb_next",
        "f_back", "f_locals", "f_globals", "f_builtins", "f_code", "f_trace",
        "gi_frame", "cr_frame", "ag_frame", "gi_code", "cr_code",
        "__code__", "__closure__", "cell_contents",
        "sys", "_sys", "builtins", "bltns", "inspect", "modules", "__import__",
        "get_objects", "get_referrers", "get_referents", "_current_frames", "_getframe",
        "getouterframes", "currentframe", "import_module",
        "__loader__", "__spec__", "__file__", "__path__", "__package__", "__cached__"
      ],
      "_import_policy": "ALLOWLIST: a submission may import ONLY these top-level modules; everything else (escapes + alternate GPU-compute libraries that could matmul outside torch's interposed view) is rejected.",
      "allow_import_modules": [
        "torch", "triton",
        "math", "cmath", "typing", "__future__", "dataclasses", "functools", "itertools",
        "collections", "enum", "numbers", "warnings"
      ],
      "forbidden_toplevel_defs": ["get_inputs", "get_flops", "get_bytes"],
      "require_kernel_fn": true,
      "require_triton_kernel": true
    },
    "runtime": {
      "denied_fn_names": [
        "matmul", "mm", "bmm", "addmm", "addbmm", "baddbmm", "mv", "dot", "vdot",
        "inner", "outer", "ger", "tensordot", "einsum", "kron", "chain_matmul",
        "linear", "conv1d", "conv2d", "conv3d",
        "conv_transpose1d", "conv_transpose2d", "conv_transpose3d",
        "scaled_dot_product_attention",
        "softmax", "log_softmax", "layer_norm", "rms_norm", "group_norm",
        "silu", "glu", "__matmul__", "__imatmul__",
        "_scaled_mm", "_int_mm"
      ],
      "deny_aten_ops": [
        "mm", "matmul", "bmm", "addmm", "addbmm", "baddbmm", "_addmm_activation",
        "mv", "dot", "vdot", "inner", "outer", "ger", "tensordot", "einsum",
        "linear", "_linear",
        "convolution", "_convolution", "conv1d", "conv2d", "conv3d",
        "conv_transpose1d", "conv_transpose2d", "conv_transpose3d",
        "cudnn_convolution", "cudnn_convolution_transpose",
        "scaled_dot_product_attention",
        "_scaled_dot_product_flash_attention", "_scaled_dot_product_efficient_attention",
        "_scaled_dot_product_cudnn_attention", "_scaled_dot_product_attention_math",
        "_flash_attention_forward", "_efficient_attention_forward",
        "softmax", "_softmax", "_safe_softmax", "log_softmax", "_log_softmax",
        "layer_norm", "native_layer_norm", "rms_norm", "_fused_rms_norm",
        "group_norm", "native_group_norm",
        "silu", "silu_", "glu",
        "_scaled_mm", "_int_mm", "_weight_int8pack_mm", "_weight_int4pack_mm",
        "_convert_weight_to_int4pack", "_mixed_dtypes_linear"
      ]
    }
  },

  "scoring": {
    "primary_axis": "speedup_vs_champion",
    "_axis_comment": "Speedup of the challenger kernel over the CURRENT CHAMPION kernel (champions/<track>/kernel.py), re-run fresh and interleaved in the same sealed job. The PyTorch reference is the correctness oracle ONLY, never the performance baseline.",
    "correctness": "hard_gate",
    "guard_axes": {
      "peak_vram_mb": { "max_regression_pct": 5.0 }
    },
    "significance": {
      "test": "mann_whitney_u",
      "_test_comment": "Nonparametric: GPU clock-boost is often bimodal, so a Welch t-test misfires. Bootstrap CI on the median speedup ratio is an acceptable alternative.",
      "n_blocks": 30,
      "min_improvement_pct": 5.0,
      "_margin_comment": "Starting value; calibrate from the first champion's measured CoV. Must sit above the box's resolvable noise floor or the crown thrashes on noise.",
      "p_value_threshold": 0.01,
      "warmup": 25,
      "rep": 100
    },
    "seed": { "source": "pr_head_sha", "hex_chars": 16 },
    "champion_rerun": "fresh_interleaved",
    "reported_only": ["throughput_tflops", "pct_peak_compute", "pct_peak_bandwidth", "bottleneck"]
  },

  "gittensor_repo_config": {
    "_comment": "Mirrors the SN74/Gittensor per-repo RepositoryConfig, VERIFIED against entrius/gittensor (gittensor/validator/utils/load_weights.py + weights/master_repositories.json). NOTES: (1) emission_share is SET BY THE GITTENSOR TEAM, not self-served (0.01 is a placeholder; the SUM across ALL repos must be <= 1.0, live repos run ~0.004-0.05). (2) King-of-the-hill: the cco-winner-<track> label is read from the winning PR (NOT the issue) via label_resolution.resolve_trusted_label_multiplier(pr.labels); default_label_multiplier 0 + fixed_base_score 1.0 make only the crown-holder earn. (3) trusted_label_pipeline true lets a CCO bot/App-applied label (actor_association=NULL) count. (4) eligibility zeros let a single crowned winner score (defaults are min_valid_merged_prs 3 / min_credibility 0.80). (5) scoring.time_decay is FLATTENED (min_multiplier 1.0) because Gittensor decays reward by TIME-SINCE-MERGE by default (50% at 10d, 5% floor, gone from lookback at 30d), which would erode 'earn while you hold the crown' -- the team must approve this override. nested eligibility/scoring objects REJECT unknown keys.",
    "emission_share": 0.1,
    "issue_discovery_share": 0.0,
    "maintainer_cut": 0.0,
    "trusted_label_pipeline": true,
    "label_multipliers": {
      "cco-winner-rms_norm": 1.0,
      "cco-winner-matmul": 1.0,
      "cco-winner-qkv_part_rope": 1.0,
      "cco-winner-swiglu_input_quant": 1.0,
      "cco-winner-dsa_forward": 1.0
    },
    "default_label_multiplier": 0.0,
    "fixed_base_score": 1.0,
    "eligibility": {
      "min_valid_merged_prs": 0,
      "min_credibility": 0.0,
      "min_valid_solved_issues": 0,
      "min_issue_credibility": 0.0
    },
    "scoring": {
      "pr_lookback_days": 90,
      "time_decay": {
        "grace_period_hours": 8760,
        "sigmoid_midpoint_days": 36500,
        "sigmoid_steepness": 0.4,
        "min_multiplier": 1.0
      }
    }
  },

  "miner_limits": {
    "prs_per_24h_per_hotkey": 1,
    "new_pr_resets_cooldown": true,
    "credibility_floor_for_banlist": 0.1
  },

  "gate4": {
    "_comment": "v1 posture: canonical rerun on a trusted, pinned GPU host; hardware attestation deferred to v2 (GPU confidential-compute / TEE). The GPU SKU is pinned in runtime/gpu.config and is part of the locked 'model'.",
    "attestation": "deferred_v2",
    "egress": "deny_all",
    "exclusive_gpu": true,
    "lock_clocks": true
  }
}
